generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum ComponentType {
  RESTAURADOR
  SECCIONADOR
  CUCHILLA_POLAR
  CUCHILLA_OPERACION_GRUPO
  CUCHILLA_UNIPOLAR
  FUSIBLE_RAMAL
}

enum VehicleStatus {
  ACTIVO
  MANTENIMIENTO
  BAJA
}

model ElectricalComponent {
  id        String        @id @default(cuid())
  type      ComponentType
  code      String        @unique
  name      String
  zona      String?
  alias     String?
  brand     String
  imageUrl  String?
  latitude  Float
  longitude Float
  icc       Float
  swept     Boolean       @default(false)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([type])
  @@index([code])
}

model Diagrama {
  id                      String               @id @default(cuid())
  nombre                  String
  urlPdf                  String
  zona                    String
  createdAt               DateTime             @default(now())
  componentesInteractivos DiagramaComponente[]
  puntosIcc               DiagramaIccPoint[]
}

model DiagramaIccPoint {
  id            String   @id @default(cuid())
  diagramaId    String
  diagrama      Diagrama @relation(fields: [diagramaId], references: [id], onDelete: Cascade)
  iccMonofasica Float
  iccTrifasica  Float
  xRelativo     Float
  yRelativo     Float
  createdAt     DateTime @default(now())

  @@index([diagramaId])
}

model DiagramaComponente {
  id         String   @id @default(cuid())
  diagramaId String
  diagrama   Diagrama @relation(fields: [diagramaId], references: [id], onDelete: Cascade)
  codigoCFE  String
  xRelativo  Float
  yRelativo  Float

  @@index([diagramaId])
  @@index([codigoCFE])
}

model Vehicle {
  id              String        @id @default(cuid())
  economicNumber  String        @unique
  plate           String        @unique
  brand           String
  model           String
  year            Int
  totalKm         Float         @default(0)
  status          VehicleStatus @default(ACTIVO)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  dailyLogs       DailyLog[]

  @@index([status])
  @@index([plate])
}

model DailyLog {
  id        String   @id @default(cuid())
  vehicleId String
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  entryTime DateTime
  exitTime  DateTime?
  kmToday   Float
  notes     String?
  createdAt DateTime @default(now())

  @@index([vehicleId])
  @@index([date])
}
